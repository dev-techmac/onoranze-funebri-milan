{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"title": "Libre Baskerville & DM Sans",
	"slug": "typography-preset-3",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"name": "Libre Baskerville",
					"slug": "libre-baskerville",
					"fontFamily": "Libre Baskerville, serif",
					"fontFace": [
						{
							"fontFamily": "Libre Baskerville",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/Libre_Baskerville/LibreBaskerville-Bold.ttf"
							]
						}
					]
				},
				{
					"name": "DM Sans",
					"slug": "dm-sans",
					"fontFamily": "DM Sans, sans-serif",
					"fontFace": [
						{
							"fontFamily": "DM Sans",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/DM_Sans/DMSans-Regular.ttf"
							]
						},
						{
							"fontFamily": "DM Sans",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/DM_Sans/DMSans-SemiBold.ttf"
							]
						}
					]
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|dm-sans",
			"fontSize": "var:preset|font-size|medium",
			"letterSpacing": "-0.18px",
			"lineHeight": "1.5"
		},
		"blocks": {
			"core/post-author-name": {
				"typography": {
					"fontWeight": "400"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontWeight": "400"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontWeight": "400",
					"letterSpacing": "-0.96px"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontSize": "var:preset|font-size|x-large",
					"fontWeight": "400"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontFamily": "var:preset|font-family|dm-sans",
							"fontWeight": "400",
							"letterSpacing": "-0.14px"
						}
					}
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var:preset|font-family|dm-sans",
					"fontWeight": "600",
					"letterSpacing": "-0.18px"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontSize": "var:preset|font-size|x-large"
				}
			}
		},
		"elements": {
			"button": {
				"typography": {
					"fontFamily": "var:preset|font-family|dm-sans",
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "400",
					"letterSpacing": "-0.36px"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontSize": "48px",
					"letterSpacing": "-0.96px"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontSize": "38px",
					"letterSpacing": "-0.96px"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontSize": "32px",
					"letterSpacing": "-0.64px"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontSize": "28px",
					"letterSpacing": "-0.56px"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville",
					"fontSize": "24px",
					"letterSpacing": "-0.48px"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var:preset|font-family|libre-baskerville"
				}
			}
		}
	}
}
