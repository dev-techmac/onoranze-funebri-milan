{
	"version": 3,
	"$schema": "https://schemas.wp.org/wp/6.8/theme.json",
	"title": "Playfair Display & Segoe UI",
	"slug": "typography-preset-1",
	"settings": {
		"typography": {
			"fontFamilies": [
				{
					"name": "Playfair Display",
					"slug": "playfair-display",
					"fontFamily": "Playfair Display, serif",
					"fontFace": [
						{
							"fontFamily": "Playfair Display",
							"fontStyle": "normal",
							"fontWeight": "600",
							"src": [
								"file:./assets/fonts/Playfair_Display/PlayfairDisplay-SemiBold.ttf"
							]
						},
						{
							"fontFamily": "Playfair Display",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/Playfair_Display/PlayfairDisplay-Bold.ttf"
							]
						}
					]
				},
				{
					"name": "Segoe UI",
					"slug": "segoe-ui",
					"fontFamily": "Segoe UI, system-ui, -apple-system, sans-serif"
				}
			]
		}
	},
	"styles": {
		"typography": {
			"fontFamily": "var:preset|font-family|segoe-ui",
			"fontSize": "var:preset|font-size|medium",
			"letterSpacing": "-0.18px",
			"lineHeight": "1.5"
		},
		"blocks": {
			"core/post-author-name": {
				"typography": {
					"fontWeight": "400"
				}
			},
			"core/post-terms": {
				"typography": {
					"fontWeight": "400"
				}
			},
			"core/post-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontWeight": "400",
					"letterSpacing": "-0.96px"
				}
			},
			"core/pullquote": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "var:preset|font-size|x-large",
					"fontWeight": "400"
				},
				"elements": {
					"cite": {
						"typography": {
							"fontFamily": "var:preset|font-family|segoe-ui",
							"fontWeight": "400",
							"letterSpacing": "-0.14px"
						}
					}
				}
			},
			"core/quote": {
				"typography": {
					"fontFamily": "var:preset|font-family|segoe-ui",
					"fontWeight": "600",
					"letterSpacing": "-0.18px"
				}
			},
			"core/site-title": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "var:preset|font-size|x-large"
				}
			}
		},
		"elements": {
			"button": {
				"typography": {
					"fontFamily": "var:preset|font-family|segoe-ui",
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "400",
					"letterSpacing": "-0.36px"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display"
				}
			},
			"h1": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "48px",
					"letterSpacing": "-0.96px"
				}
			},
			"h2": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "38px",
					"letterSpacing": "-0.96px"
				}
			},
			"h3": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "32px",
					"letterSpacing": "-0.64px"
				}
			},
			"h4": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "28px",
					"letterSpacing": "-0.56px"
				}
			},
			"h5": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display",
					"fontSize": "24px",
					"letterSpacing": "-0.48px"
				}
			},
			"h6": {
				"typography": {
					"fontFamily": "var:preset|font-family|playfair-display"
				}
			}
		}
	}
}
